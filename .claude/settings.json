{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/h0-session-start.ps1\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/h2-isolation.ps1\""
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/h3-stage-gate.ps1\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/h1-verify-source.ps1\""
          },
          {
            "type": "command",
            "shell": "powershell",
            "command": "powershell -NoProfile -File \"${CLAUDE_PROJECT_DIR}/.claude/hooks/h4-skill-lines.ps1\""
          }
        ]
      }
    ]
  }
}
